{
  "name": "bodygood-marketing-os",
  "private": true,
  "version": "0.1.0",
  "description": "Body Good Marketing OS — AI-powered marketing agency operating system for a GLP-1 telehealth practice",
  "type": "module",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "postinstall": "npm --prefix client install && npm --prefix server install",
    "build": "npm --prefix client run build",
    "dev": "concurrently -k -n server,client -c yellow,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "start": "node server/index.js",
    "seed": "npm --prefix server run seed",
    "seed:ceo": "npm --prefix server exec -- node db/seed/create-ceo-user.js"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
